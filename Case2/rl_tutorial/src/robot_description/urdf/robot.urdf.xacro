<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="robot">

  <!-- ======= Parameters Body ======= -->
  <xacro:property name="base_length" value="0.38"/>
  <xacro:property name="base_width"  value="0.26"/>
  <xacro:property name="base_height" value="0.12"/>
  
  <xacro:property name="wheel_radius" value="0.06"/>
  <xacro:property name="wheel_width"  value="0.03"/>
  
  <xacro:property name="base_link_z" value="${wheel_radius + base_height/2.0}"/>

  <xacro:property name="wheel_separation" value="0.32"/>

  <xacro:property name="lidar_x" value="0.14"/>
  <xacro:property name="lidar_z" value="${base_height/2.0 + 0.08}"/>

  <xacro:property name="caster_radius" value="0.02"/>
  <xacro:property name="caster_x" value="${base_length/2.0 - caster_radius - 0.01}"/>
  <xacro:property name="caster_z" value="${-base_height/2.0 - wheel_radius + caster_radius}"/>

  <xacro:property name="camera_x" value="${base_length/2.0 - 0.03}"/>
  <xacro:property name="camera_y" value="0.0"/>
  <xacro:property name="camera_z" value="${base_height/2.0 + 0.02}"/>

  <!-- ======= Materials  ======= -->
  <material name="body_blue">
    <color rgba="0.10 0.40 0.95 1.0"/>
  </material>

  <material name="accent_orange">
    <color rgba="1.00 0.55 0.05 1.0"/>
  </material>

  <material name="wheel_black">
    <color rgba="0.08 0.08 0.08 1.0"/>
  </material>

  <material name="camera_pink">
    <color rgba="1.0 0.2 0.7 1.0"/>
  </material>

  <material name="camera_green">
    <color rgba="0.2 1.0 0.2 1.0"/>
  </material>

  <!-- ======= Dummy root  ======= -->
  <link name="base_footprint"/>

  <joint name="base_footprint_to_base_link" type="fixed">
    <origin xyz="0 0 ${base_link_z}" rpy="0 0 0"/>
    <parent link="base_footprint"/>
    <child link="base_link"/>
  </joint>

  <!-- ======= Chassis  ======= -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <material name="body_blue"/>
    </visual>

    <visual name="front_marker">
      <origin xyz="${base_length/2.0 - 0.03} 0 ${base_height/2.0 - 0.02}" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.04 0.04"/>
      </geometry>
      <material name="accent_orange"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length-0.04} ${base_width-0.04} ${base_height-0.04}"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="10.0"/>
      <inertia ixx="0.12" ixy="0.0" ixz="0.0" iyy="0.18" iyz="0.0" izz="0.22"/>
    </inertial>
  </link>

  <!-- ======= Wheels ======= -->
  <link name="left_wheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="-1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="wheel_black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="-1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.8"/>
      <inertia ixx="0.0010" ixy="0.0" ixz="0.0" iyy="0.0010" iyz="0.0" izz="0.0010"/>
    </inertial>
  </link>

  <link name="right_wheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="-1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="wheel_black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="-1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.8"/>
      <inertia ixx="0.0010" ixy="0.0" ixz="0.0" iyy="0.0010" iyz="0.0" izz="0.0010"/>
    </inertial>
  </link>

  <!-- Caster swivel link -->
  <link name="caster_swivel_front_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
    </inertial>
  </link>

  <link name="caster_swivel_back_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
    </inertial>
  </link>

  <!-- Caster wheel -->
  <link name="caster_wheel_front_link">
    <visual>
      <origin xyz="0 0 0" rpy="-1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="${caster_radius}" length="0.01"/>
      </geometry>
      <material name="wheel_black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="-1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="${caster_radius}" length="0.01"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
    </inertial>
  </link>

   <link name="caster_wheel_back_link">
    <visual>
      <origin xyz="0 0 0" rpy="-1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="${caster_radius}" length="0.01"/>
      </geometry>
      <material name="wheel_black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="-1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="${caster_radius}" length="0.01"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
    </inertial>
  </link>

  <!-- Wheel centers are at z = -base_height/2 so absolute z = wheel_radius -->
  <joint name="left_wheel_joint" type="continuous">
    <origin xyz="0 ${wheel_separation/2.0} -${base_height/2.0}" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="left_wheel_link"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="right_wheel_joint" type="continuous">
    <origin xyz="0 -${wheel_separation/2.0} -${base_height/2.0}" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="right_wheel_link"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="caster_swivel_front_joint" type="continuous">
    <origin xyz="${caster_x} 0 ${caster_z}" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="caster_swivel_front_link"/>
    <axis xyz="0 0 1"/>
  </joint>

   <joint name="caster_swivel_back_joint" type="continuous">
    <origin xyz="-${caster_x} 0 ${caster_z}" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="caster_swivel_back_link"/>
    <axis xyz="0 0 1"/>
  </joint>

  <joint name="caster_wheel_front_joint" type="continuous">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="caster_swivel_front_link"/>
    <child link="caster_wheel_front_link"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="caster_wheel_back_joint" type="continuous">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="caster_swivel_back_link"/>
    <child link="caster_wheel_back_link"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ======= LiDAR  ======= -->
  <link name="lidar_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.05"/>
      </geometry>
      <material name="accent_orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.05"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.25"/>
      <inertia ixx="0.0002" ixy="0.0" ixz="0.0" iyy="0.0002" iyz="0.0" izz="0.0002"/>
    </inertial>
  </link>

  <joint name="lidar_joint" type="fixed">
    <origin xyz="0 0 ${lidar_z}" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="lidar_link"/>
  </joint>

  <!-- ======= Front Camera ======= -->
  <link name="camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.04 0.03"/>
      </geometry>
      <material name="camera_pink"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.04 0.03"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.18"/>
      <inertia ixx="0.00018" ixy="0" ixz="0" iyy="0.00018" iyz="0" izz="0.00018"/>
    </inertial>
  </link>

  <link name="camera_optical_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.006 0.028 0.021"/>
      </geometry>
      <material name="camera_green"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.006 0.028 0.021"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.02"/>
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
    </inertial>
  </link>

  <joint name="camera_joint" type="fixed">
    <origin xyz="${camera_x} ${camera_y} ${camera_z}" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="camera_link"/>
  </joint>

  <joint name="camera_optical_joint" type="fixed">
    <origin xyz="0.033 0 0" rpy="0 0 0"/>
    <parent link="camera_link"/>
    <child link="camera_optical_link"/>
  </joint>

  <!-- ======= Gazebo-specific ======= -->
  <gazebo reference="base_link">
    <material>Gazebo/Blue</material>
    <mu1>0.8</mu1>
    <mu2>0.8</mu2>
  </gazebo>

  <gazebo reference="left_wheel_link">
    <material>Gazebo/Black</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>

  <gazebo reference="right_wheel_link">
    <material>Gazebo/Black</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>

  <gazebo reference="caster_wheel_front_link">
    <material>Gazebo/Black</material>
    <mu1>0.2</mu1>
    <mu2>0.2</mu2>
  </gazebo>

  <gazebo reference="caster_wheel_back_link">
    <material>Gazebo/Black</material>
    <mu1>0.2</mu1>
    <mu2>0.2</mu2>
  </gazebo>

  <gazebo reference="camera_link">
    <material>Gazebo/Purple</material>
  </gazebo>

  <gazebo reference="camera_optical_link">
    <material>Gazebo/Green</material>
  </gazebo>

  <!-- 2D LiDAR sensor (ray) + gazebo_ros_ray_sensor plugin publishing LaserScan on /robot/scan -->
  <gazebo reference="lidar_link">
    <material>Gazebo/Orange</material>

    <sensor name="lidar" type="ray">
      <always_on>true</always_on>
      <update_rate>10</update_rate>
      <visualize>false</visualize>

      <ray>
        <scan>
          <horizontal>
            <samples>120</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159265359</min_angle>
            <max_angle>3.14159265359</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.12</min>
          <max>10.0</max>
          <resolution>0.01</resolution>
        </range>
      </ray>

      <plugin name="gazebo_ros_ray_sensor" filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <namespace>/robot</namespace>
          <remapping>~/out:=scan</remapping>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>lidar_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <!-- Differential drive plugin: /robot/cmd_vel -> /robot/odom -->
  <gazebo>
    <plugin name="gazebo_ros_diff_drive" filename="libgazebo_ros_diff_drive.so">
      <ros>
        <namespace>/robot</namespace>
      </ros>

      <update_rate>50</update_rate>

      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>

      <wheel_separation>${wheel_separation}</wheel_separation>
      <wheel_diameter>${2.0*wheel_radius}</wheel_diameter>

      <max_wheel_torque>15.0</max_wheel_torque>
      <max_wheel_acceleration>10.0</max_wheel_acceleration>

      <command_topic>cmd_vel</command_topic>

      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>false</publish_wheel_tf>

      <odometry_topic>odom</odometry_topic>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
    </plugin>
  </gazebo>

  <!-- Gazebo joint_state_publisher (tf) -->
  <gazebo>
    <plugin name="gazebo_ros_joint_state_publisher"
            filename="libgazebo_ros_joint_state_publisher.so">
      <ros>
        <namespace>/robot</namespace>
      </ros>
      <update_rate>50</update_rate>
      <joint_name>left_wheel_joint</joint_name>
      <joint_name>right_wheel_joint</joint_name>
      <joint_name>caster_swivel_front_joint</joint_name>
      <joint_name>caster_wheel_front_joint</joint_name>
      <joint_name>caster_swivel_back_joint</joint_name>
      <joint_name>caster_wheel_back_joint</joint_name>
    </plugin>
  </gazebo>

  <!-- Gazebo Camera -->
  <gazebo reference="camera_link">
    <sensor name="front_camera" type="camera">
      <always_on>true</always_on>
      <update_rate>15</update_rate>
      <visualize>false</visualize>

      <camera name="front_camera">
        <horizontal_fov>1.047</horizontal_fov> <!-- ~60 deg -->
        <image>
          <width>720</width>
          <height>576</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>30.0</far>
        </clip>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.002</stddev>
        </noise>
      </camera>

      <!-- Publishes /robot/camera/image_raw and /robot/camera/camera_info -->
      <plugin name="gazebo_ros_camera" filename="libgazebo_ros_camera.so">
        <ros>
          <namespace>/robot</namespace>
        </ros>

        <camera_name>camera</camera_name>
        <frame_name>camera_link</frame_name>

        <image_topic_name>camera/image_raw</image_topic_name>
        <camera_info_topic_name>camera/camera_info</camera_info_topic_name>
      </plugin>
    </sensor>
  </gazebo>

</robot>
